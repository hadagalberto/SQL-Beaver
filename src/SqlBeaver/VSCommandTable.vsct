<?xml version="1.0" encoding="utf-8"?>
<CommandTable xmlns="http://schemas.microsoft.com/VisualStudio/2005-10-18/CommandTable" xmlns:xs="http://www.w3.org/2001/XMLSchema">
  <Extern href="stdidcmd.h" />
  <Extern href="vsshlids.h" />

  <Commands package="guidSqlBeaverPackage">
    <Menus>
      <Menu guid="guidSqlBeaverCmdSet" id="SqlBeaverToolbar" type="Toolbar">
        <CommandFlag>DefaultDocked</CommandFlag>
        <Strings><ButtonText>SQL Beaver</ButtonText></Strings>
      </Menu>
      <Menu guid="guidSqlBeaverCmdSet" id="SqlBeaverMenu" priority="0x0700" type="Menu">
        <Parent guid="guidSHLMainMenu" id="IDG_VS_MM_TOOLSADDINS" />
        <Strings><ButtonText>SQL Beaver</ButtonText></Strings>
      </Menu>
    </Menus>

    <Groups>
      <Group guid="guidSqlBeaverCmdSet" id="SqlBeaverMenuGroup" priority="0x0100">
        <Parent guid="guidSqlBeaverCmdSet" id="SqlBeaverMenu" />
      </Group>
      <Group guid="guidSqlBeaverCmdSet" id="SqlBeaverToolbarGroup" priority="0x0100">
        <Parent guid="guidSqlBeaverCmdSet" id="SqlBeaverToolbar" />
      </Group>
    </Groups>

    <Buttons>
      <Button guid="guidSqlBeaverCmdSet" id="cmdidFormatDocument" priority="0x0100" type="Button">
        <Parent guid="guidSqlBeaverCmdSet" id="SqlBeaverMenuGroup" />
        <Strings><ButtonText>Format Document (SQL Beaver)</ButtonText></Strings>
      </Button>
      <Button guid="guidSqlBeaverCmdSet" id="cmdidFindObject" priority="0x0101" type="Button">
        <Parent guid="guidSqlBeaverCmdSet" id="SqlBeaverMenuGroup" />
        <Strings><ButtonText>Localizar objeto…</ButtonText></Strings>
      </Button>
      <Button guid="guidSqlBeaverCmdSet" id="cmdidGoToDefinition" priority="0x0102" type="Button">
        <Parent guid="guidSqlBeaverCmdSet" id="SqlBeaverMenuGroup" />
        <Strings><ButtonText>Ir para definição (SQL Beaver)</ButtonText></Strings>
      </Button>
      <Button guid="guidSqlBeaverCmdSet" id="cmdidFindReferences" priority="0x0103" type="Button">
        <Parent guid="guidSqlBeaverCmdSet" id="SqlBeaverMenuGroup" />
        <Strings><ButtonText>Localizar referências (SQL Beaver)</ButtonText></Strings>
      </Button>
      <Button guid="guidSqlBeaverCmdSet" id="cmdidQueryHistory" priority="0x0104" type="Button">
        <Parent guid="guidSqlBeaverCmdSet" id="SqlBeaverMenuGroup" />
        <Strings><ButtonText>Histórico de consultas</ButtonText></Strings>
      </Button>
      <Button guid="guidSqlBeaverCmdSet" id="cmdidRecoverSession" priority="0x0105" type="Button">
        <Parent guid="guidSqlBeaverCmdSet" id="SqlBeaverMenuGroup" />
        <Strings><ButtonText>Recuperar consultas…</ButtonText></Strings>
      </Button>
      <Button guid="guidSqlBeaverCmdSet" id="cmdidEnvironments" priority="0x0106" type="Button">
        <Parent guid="guidSqlBeaverCmdSet" id="SqlBeaverMenuGroup" />
        <Strings><ButtonText>Ambientes (cores)…</ButtonText></Strings>
      </Button>
    </Buttons>
  </Commands>

